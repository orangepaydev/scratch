<?xml version="1.0" encoding="UTF-8"?>
<xs:schema 	xmlns="urn:tc:rtp:xsd:rtp.message.01"
              xmlns:xs="http://www.w3.org/2001/XMLSchema"

              xmlns:ah="urn:iso:std:iso:20022:tech:xsd:head.001.001.04"
              xmlns:signOnReq="urn:iso:std:iso:20022:tech:xsd:admn.001.001.01"
              xmlns:signOnResp="urn:iso:std:iso:20022:tech:xsd:admn.002.001.01"
              xmlns:signOffReq="urn:iso:std:iso:20022:tech:xsd:admn.003.001.01"
              xmlns:signOffResp="urn:iso:std:iso:20022:tech:xsd:admn.004.001.01"
              xmlns:echoReq="urn:iso:std:iso:20022:tech:xsd:admn.005.001.01"
              xmlns:echoResp="urn:iso:std:iso:20022:tech:xsd:admn.006.001.01"
              xmlns:msgRjct="urn:iso:std:iso:20022:tech:xsd:admi.002.001.01"
              xmlns:sysEvtNtfctn="urn:iso:std:iso:20022:tech:xsd:admi.004.001.02"

              elementFormDefault="qualified"
              targetNamespace="urn:tc:rtp:xsd:rtp.message.01">

    <xs:import schemaLocation="../head/head.001.001.04.xsd" namespace="urn:iso:std:iso:20022:tech:xsd:head.001.001.04"/>
    <xs:import schemaLocation="../admn/admn.001.001.01.xsd" namespace="urn:iso:std:iso:20022:tech:xsd:admn.001.001.01"/>
    <xs:import schemaLocation="../admn/admn.002.001.01.xsd" namespace="urn:iso:std:iso:20022:tech:xsd:admn.002.001.01"/>
    <xs:import schemaLocation="../admn/admn.003.001.01.xsd" namespace="urn:iso:std:iso:20022:tech:xsd:admn.003.001.01"/>
    <xs:import schemaLocation="../admn/admn.004.001.01.xsd" namespace="urn:iso:std:iso:20022:tech:xsd:admn.004.001.01"/>
    <xs:import schemaLocation="../admn/admn.005.001.01.xsd" namespace="urn:iso:std:iso:20022:tech:xsd:admn.005.001.01"/>
    <xs:import schemaLocation="../admn/admn.006.001.01.xsd" namespace="urn:iso:std:iso:20022:tech:xsd:admn.006.001.01"/>
    <xs:import schemaLocation="../admi/admi.002.001.01.xsd" namespace="urn:iso:std:iso:20022:tech:xsd:admi.002.001.01"/>
    <xs:import schemaLocation="../admi/admi.004.001.02.xsd" namespace="urn:iso:std:iso:20022:tech:xsd:admi.004.001.02"/>

    <xs:element name="Message" type="MessageType"/>
    <xs:complexType name="MessageType">
        <xs:sequence>
            <xs:element ref="ah:AppHdr"/>
            <xs:choice>
                <xs:element ref="signOnReq:SignOnRequest"/>
                <xs:element ref="signOnResp:SignOnResponse"/>
                <xs:element ref="signOffReq:SignOffRequest"/>
                <xs:element ref="signOffResp:SignOffResponse"/>
                <xs:element ref="echoReq:EchoRequest"/>
                <xs:element ref="echoResp:EchoResponse"/>
                <xs:element ref="msgRjct:Document"/>
                <xs:element ref="sysEvtNtfctn:Document"/>
            </xs:choice>
        </xs:sequence>
    </xs:complexType>
</xs:schema>